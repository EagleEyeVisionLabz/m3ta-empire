# build-adapter environment template
# Copy to .env (git-ignored) and fill in real values.
# Never commit .env. .gitignore covers it; verify with `git check-ignore`.

# --- External build runtime ---------------------------------------------------
# The adapter is runtime-agnostic; fill these in for whichever build agent
# you wire in. The product name lives here only; no other file references it.
EXTERNAL_BUILD_AGENT_API_KEY=
EXTERNAL_BUILD_AGENT_ENDPOINT=
EXTERNAL_BUILD_AGENT_MODEL_ID=

# --- M3ta-OS routing backbone ------------------------------------------------
# Local LiteLLM proxy. Default is the convention used elsewhere in the repo.
M3TA_LITELLM_BASE_URL=http://localhost:4000/v1

# --- MCP endpoints (override only if running non-default ports) ---------------
M3TA_MCP_NOTION_URL=http://localhost:7710
M3TA_MCP_SLACK_URL=http://localhost:7711
M3TA_MCP_ATTIO_URL=http://localhost:7712
M3TA_MCP_OBSIDIAN_URL=http://localhost:7713

# --- Memory and audit sinks ---------------------------------------------------
OBSIDIAN_VAULT_PATH=
NOTION_API_KEY=
NOTION_TASK_DATABASE_ID=

# --- Slack alerts -------------------------------------------------------------
SLACK_BOT_TOKEN=
SLACK_ALERT_CHANNEL=

# --- CRM handoff (optional) ---------------------------------------------------
ATTIO_API_KEY=
ATTIO_WORKSPACE_ID=

# --- Classifier tuning --------------------------------------------------------
# Confidence threshold below which the classifier emits a null model_route_hint
# rather than guessing. Range 0.0 - 1.0; default 0.65.
CLASSIFIER_CONFIDENCE_THRESHOLD=0.65
